# Hardening Photo Proofing App

# 1. Wyłącz listowanie katalogów
Options -Indexes

# 2. Chroń pliki bazy danych i logi (na wypadek gdyby sub-htaccess nie działał)
<FilesMatch "\.(sqlite|log|enc)$">
    <IfModule authz_core_module>
        Require all denied
    </IfModule>
    <IfModule !authz_core_module>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Wyjątek dla zdjęć .enc serwowanych przez serve_image.php
# (Brak potrzeby - serve_image.php odczytuje je lokalnie, a FilesMatch blokuje dostęp bezpośredni przez URL)

# 3. Zablokuj dostęp do plików wrażliwych
<Files "config.php">
    <IfModule authz_core_module>
        Require all denied
    </IfModule>
</FilesMatch>

# 4. Nagłówki bezpieczeństwa
<IfModule mod_headers.c>
    Header set X-XSS-Protection "1; mode=block"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-Content-Type-Options "nosniff"
    Header set Referrer-Policy "no-referrer-when-downgrade"
</IfModule>

# 5. Blokada dostępu do skryptów instalacyjnych (opcjonalnie, skoro dodaliśmy auth)
# Ale auth jest bezpieczniejsze.
